# Copie para .env (DotNetEnv no Program) ou defina no ambiente / Docker.

# ---- PostgreSQL (vazio = EF InMemory, apenas para dev local) ----
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=simcag_notifications;Username=postgres;Password=postgres
# Aliases legados (vão ser removidos): POSTGRES_CONNECTION, ConnectionStrings__NotificationDb

# Migrations (true = não executar no startup; útil com DB gerenciado)
# POSTGRES_MIGRATIONS_DISABLED=true

# ---- Redis (dedup + rate limit; vazio / REDIS_DISABLED=true = sem Redis) ----
REDIS__CONNECTION=localhost:6379
# Aliases legados: REDIS_CONNECTION, ConnectionStrings__Redis
# REDIS_DISABLED=true
# NOTIFICATION_DEDUP_TTL_HOURS=24
# NOTIFICATION_MAX_SENDS_PER_USER_PER_HOUR=30
# REDIS_KEY_PREFIX=notif

# ---- RabbitMQ ----
RABBITMQ__HOST=localhost
RABBITMQ__PORT=5672
RABBITMQ__USERNAME=guest
RABBITMQ__PASSWORD=guest
RABBITMQ__VIRTUALHOST=/
# Fila padrão "alert-triggered-events"; "alerts" para eventos legados
# RABBITMQ_QUEUE_ALERT_TRIGGERED=alert-triggered-events
# RABBITMQ_QUEUE_ALERT_CREATED=alerts
# RABBITMQ__EVENTS_EXCHANGE=events

# ---- SMTP (aceita os dois formatos) ----
SMTP__HOST=smtp.gmail.com
SMTP__PORT=587
SMTP__USERNAME=
SMTP__PASSWORD=
# SMTP__ENABLESSL=true

# ---- SMS (Twilio; aliases alinhados à doc) ----
TWILIO__ACCOUNTSID=
TWILIO__AUTHTOKEN=
TWILIO__FROMNUMBER=
# SMS_PROVIDER_API_KEY=  (ou TWILIO__AUTHTOKEN)
# SMS_PROVIDER_FROM=
